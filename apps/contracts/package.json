{
  "name": "@mutuals/contracts",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "dev": "hardhat node",
    "build": "hardhat compile",
    "build:clean": "cross-env bun clean && bun build",
    "clean": "cross-env hardhat clean && git clean -xdf artifacts .deps cache node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "test": "cross-env SOLC_PROFILE=test && hardhat test",
    "test:clean": "cross-env bun clean && bun test",
    "check": "solhint --config .solhint.json --ignore-path .solhintignore contracts/**/*.sol",
    "fix": "bun lint:solhint -- --fix",
    "typechain": "hardhat typechain",
    "deploy:local": "hardhat deploy --network localhost",
    "deploy:staging": "cross-env SOLC_PROFILE=production hardhat deploy --network holesky",
    "deploy:production": "hardhat deploy --network mainnet",
    "task:accounts": "hardhat accounts"
  },
  "devDependencies": {
    "@mutuals/typescript-config": "workspace:*",
    "@nomicfoundation/ethereumjs-util": "^9.0.4",
    "@nomicfoundation/hardhat-chai-matchers": "^3.0.0",
    "@nomicfoundation/hardhat-ethers": "^4.0.5",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.4",
    "@nomicfoundation/hardhat-verify": "^3.0.11",
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@openzeppelin/hardhat-upgrades": "^3.5.0",
    "@openzeppelin/merkle-tree": "^1.0.8",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^5.2.3",
    "@types/dotenv-defaults": "^5.0.0",
    "@types/dotenv-parse-variables": "^2.0.3",
    "@types/fs-extra": "^11.0.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "defender-admin-client": "1.38.3-rc.0",
    "dotenv": "^17.3.1",
    "dotenv-defaults": "^6.0.0",
    "dotenv-parse-variables": "^2.0.0",
    "ethers": "^6.16.0",
    "fs-extra": "^11.3.4",
    "hardhat": "^3.1.10",
    "hardhat-contract-sizer": "^2.10.1",
    "hardhat-deploy": "^2.0.1",
    "hardhat-deploy-ethers": "^0.4.2",
    "hardhat-gas-reporter": "^2.3.0",
    "hardhat-ignore-warnings": "^0.3.0",
    "hardhat-tracer": "^3.4.0",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.3",
    "solhint": "^6.0.3",
    "solhint-plugin-prettier": "^0.1.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  }
}
