{
  "name": "@mutuals/payload",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./*": "./src/*.ts",
    "./access": "./src/access/index.ts",
    "./blocks/*": "./src/blocks/*/index.ts",
    "./collections": "./src/collections/index.ts",
    "./fields": "./src/fields/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./utils": "./src/utils/index.ts",
    "./payload-types": "./src/payload-types.ts",
    "./payload-config/*": "./src/payload.config.ts"
  },
  "scripts": {
    "clean": "git clean -xdf src/payload-types.ts node_modules",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "test": "bun run test:int && bun run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" bun exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "peerDependencies": {
    "@payloadcms/db-postgres": ">=3.78.0",
    "@payloadcms/next": ">=3.78.0",
    "@payloadcms/plugin-redirects": ">=3.78.0",
    "@payloadcms/plugin-seo": ">=3.78.0",
    "@payloadcms/richtext-lexical": ">=3.78.0",
    "@payloadcms/storage-vercel-blob": ">=3.78.0",
    "@payloadcms/ui": ">=3.78.0",
    "graphql": ">=16",
    "next": ">=16.1.6",
    "payload": ">=3.78.0",
    "react": ">=19.2.4",
    "react-dom": ">=19.2.4"
  },
  "dependencies": {
    "dotenv": "17.3.1"
  },
  "devDependencies": {
    "@mutuals/typescript-config": "workspace:*",
    "@payloadcms/db-postgres": "3.78.0",
    "@payloadcms/next": "3.78.0",
    "@payloadcms/plugin-redirects": "3.78.0",
    "@payloadcms/plugin-seo": "3.78.0",
    "@payloadcms/richtext-lexical": "3.78.0",
    "@payloadcms/storage-vercel-blob": "3.78.0",
    "@payloadcms/ui": "3.78.0",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "cross-env": "^10.1.0",
    "graphql": "^16.12.0",
    "jsdom": "28.1.0",
    "payload": "3.78.0",
    "playwright": "1.58.2",
    "playwright-core": "1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18"
  }
}
