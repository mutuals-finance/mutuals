{
  "name": "@mutuals/graphql-client-nextjs",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./client": "./src/client/index.ts",
    "./server": "./src/server/index.ts"
  },
  "scripts": {
    "dev": "bun graphql:generate -- --watch",
    "build": "bun graphql:generate",
    "graphql:generate": "graphql-codegen --config src/graphql/codegen.ts",
    "clean": "git clean -xdf .turbo src/graphql/data/__generated__ node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "6.1.2",
    "@graphql-codegen/client-preset": "5.2.3",
    "@mutuals/typescript-config": "workspace:*",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@apollo/client-integration-nextjs": "^0.14.3",
    "@faker-js/faker": "^10.3.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "graphql": "^16.13.0",
    "msw": "^2.12.10",
    "next": "^16.1.6"
  }
}
