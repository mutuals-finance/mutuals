{
  "name": "@mutuals/graphql-client-nextjs",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./client": "./src/client/index.ts",
    "./server": "./src/server/index.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "graphql:generate": "graphql-codegen --config src/graphql/codegen.ts",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "6.1.2",
    "@graphql-codegen/client-preset": "5.2.3",
    "@mutuals/eslint-config": "workspace:*",
    "@mutuals/typescript-config": "workspace:*",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.2",
    "react": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@apollo/client-integration-nextjs": "^0.14.3",
    "@graphql-typed-document-node/core": "^3.2.0",
    "graphql": "^16.13.0",
    "next": "^16.1.6"
  }
}
